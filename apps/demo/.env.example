# Copy this file to .env.local and restart `next dev` after editing.
# These are NEXT_PUBLIC_* so they are inlined into the client bundle.
NEXT_PUBLIC_KC_URL=http://localhost:8080
NEXT_PUBLIC_KC_REALM=demo
NEXT_PUBLIC_KC_CLIENT_ID=demo-app

# Optional: full URL of a backend endpoint behind the API Gateway, used by the
# "Backend call" panel on /protected to send the access token end-to-end.
NEXT_PUBLIC_API_URL=https://gateway.example.org/api/whoami
