{
  "name": "@ricardoqmd/auth-core",
  "version": "0.0.1",
  "description": "Framework-agnostic XState machine and types for authentication flows",
  "keywords": ["auth", "xstate", "state-machine", "keycloak", "oidc"],
  "author": "ricardoqmd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ricardoqmd/auth.git",
    "directory": "packages/auth-core"
  },
  "homepage": "https://github.com/ricardoqmd/auth/tree/main/packages/auth-core",
  "bugs": "https://github.com/ricardoqmd/auth/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
