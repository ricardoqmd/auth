{
  "name": "@ricardoqmd/auth-nextjs",
  "version": "0.1.0",
  "description": "Next.js client-side bindings for @ricardoqmd/auth-core — AuthProvider, useAuth hook, RBAC helpers",
  "keywords": [
    "auth",
    "nextjs",
    "react",
    "keycloak",
    "hook",
    "rbac"
  ],
  "author": "ricardoqmd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ricardoqmd/auth.git",
    "directory": "packages/auth-nextjs"
  },
  "homepage": "https://github.com/ricardoqmd/auth/tree/main/packages/auth-nextjs",
  "bugs": "https://github.com/ricardoqmd/auth/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@ricardoqmd/auth-core": "workspace:*",
    "@xstate/react": "^5.0.5"
  },
  "peerDependencies": {
    "next": ">=14.0.0 <17.0.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
